<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/toolbar_background"
    tools:context=".ui.timer.TimerFragment">

    <!-- Etiqueta superior estilo píldora -->
    <TextView
        android:id="@+id/tv_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:background="@drawable/bg_pill_lime"
        android:paddingHorizontal="24dp"
        android:paddingVertical="8dp"
        android:text="Al fallo o muere flaco"
        android:textColor="@color/lime_green"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Contenedor del Círculo y Tiempo -->
    <FrameLayout
        android:id="@+id/timer_container"
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:layout_marginTop="24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_status">

        <!-- Círculo de fondo -->
        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            app:indicatorSize="260dp"
            app:trackThickness="10dp"
            app:trackColor="@color/white"
            android:progress="100"
            app:trackCornerRadius="10dp"/>

        <!-- Círculo de progreso Turquesa -->
        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/progress_timer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            app:indicatorSize="260dp"
            app:trackThickness="10dp"
            app:indicatorColor="@color/turquoise"
            android:progress="100"
            app:trackCornerRadius="10dp"
            app:trackColor="@android:color/transparent"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="WORK PERIOD"
                android:textColor="@color/turquoise"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.2"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tv_timer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:45"
                android:textColor="@color/white"
                android:textSize="72sp"
                android:fontFamily="sans-serif-light" />

            <TextView
                android:id="@+id/tv_sets"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Set 3 / 8"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:alpha="0.7"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

    </FrameLayout>

    <!-- Controles inferiores -->
    <LinearLayout
        android:id="@+id/controls_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@+id/timer_container"
        app:layout_constraintBottom_toTopOf="@+id/card_setup"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btn_reset"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="32dp"
            android:src="@drawable/ic_reset"
            app:backgroundTint="#2C2C2E"
            app:fabSize="mini"
            app:tint="@color/white"
            app:elevation="0dp"
            app:borderWidth="0dp"/>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btn_play_pause"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_play"
            app:backgroundTint="@color/turquoise"
            app:fabCustomSize="96dp"
            app:maxImageSize="48dp"
            app:tint="@color/black"
            app:elevation="12dp" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btn_skip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="32dp"
            android:src="@drawable/ic_skip_next"
            app:backgroundTint="#2C2C2E"
            app:fabSize="mini"
            app:tint="@color/white"
            app:elevation="0dp"
            app:borderWidth="0dp"/>

    </LinearLayout>

    <!-- Card de configuración de tiempo -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_setup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        app:cardBackgroundColor="#1C1C1E"
        app:cardCornerRadius="24dp"
        app:strokeWidth="0dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp">

                <ImageView
                    android:id="@+id/iv_work_icon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_exercises"
                    app:tint="@color/turquoise"
                    android:layout_centerVertical="true"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@id/iv_work_icon"
                    android:layout_marginStart="12dp"
                    android:text="Work Time"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_centerVertical="true"/>

                <TextView
                    android:id="@+id/tv_work_time_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="45s"
                    android:textColor="@color/turquoise"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_centerVertical="true"/>

            </RelativeLayout>

            <com.google.android.material.slider.Slider
                android:id="@+id/slider_work_time"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:valueFrom="5"
                android:valueTo="300"
                android:value="45"
                app:thumbColor="@color/turquoise"
                app:trackColorActive="@color/turquoise"
                app:trackColorInactive="#2C2C2E"
                app:haloColor="#3300E5FF"/>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="5S"
                    android:textColor="#80FFFFFF"
                    android:textSize="10sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="5M"
                    android:textColor="#80FFFFFF"
                    android:textSize="10sp"/>
            </RelativeLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>